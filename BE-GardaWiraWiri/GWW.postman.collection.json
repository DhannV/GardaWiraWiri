{
  "info": {
    "_postman_id": "garda-wira-wiri-v1",
    "name": "Garda Wira Wiri API",
    "description": "Collection lengkap untuk testing API Garda Wira Wiri.\n\n## Setup\n1. Import collection ini ke Postman\n2. Buat Environment baru dengan variabel:\n   - `base_url` = http://localhost:3000/api/v1\n   - `admin_token` (otomatis diisi setelah login admin)\n   - `client_token` (otomatis diisi setelah login client)\n   - `freelancer_token` (otomatis diisi setelah login freelancer)\n   - `project_id`, `bid_id`, `contract_id`, `payment_id`, `review_id` (otomatis diisi dari response)\n\n## Test Flow\nRegister → Login → Create Project → Bid → Accept Bid → Contract → Payment → Complete → Review",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    { "key": "admin_token", "value": "", "type": "string" },
    { "key": "client_token", "value": "", "type": "string" },
    { "key": "client2_token", "value": "", "type": "string" },
    { "key": "freelancer_token", "value": "", "type": "string" },
    { "key": "freelancer2_token", "value": "", "type": "string" },
    { "key": "project_id", "value": "", "type": "string" },
    { "key": "bid_id", "value": "", "type": "string" },
    { "key": "contract_id", "value": "", "type": "string" },
    { "key": "payment_id", "value": "", "type": "string" },
    { "key": "review_id", "value": "", "type": "string" },
    { "key": "freelancer_profile_id", "value": "", "type": "string" }
  ],
